"\nbrain_encoder, brain_projector, brain_history = train_simclr(\n    brain_train_loader, brain_val_loader, BRAIN_SAVE, model_name=\"SimCLR-Brain\"\n)","metadata":{},"outputs":[],"execution_count":null},{"id":"a036d1ee","cell_type":"code","source":"# ══════════════════════════════════════════════\n# PART 2: BRAIN — Full Analysis\n# ══════════════════════════════════════════════\nbrain_results = run_full_analysis(\n    brain_encoder, brain_train_clean_loader, brain_val_clean_loader,\n    brain_train_clean, brain_val_clean, brain_history, BRAIN_SAVE, \"SimCLR-Brain\"\n)","metadata":{},"outputs":[],"execution_count":null},{"id":"d0f5be61","cell_type":"code","source":"# ══════════════════════════════════════════════\n# PART 2: BRAIN — Cleanup GPU\n# ══════════════════════════════════════════════\ndel brain_encoder, brain_projector\ndel brain_train_loader, brain_val_loader\ndel brain_train_clean_loader, brain_val_clean_loader\nclear_gpu()","metadata":{},"outputs":[],"execution_count":null},{"id":"ffa28e22","cell_type":"markdown","source":"---\n# Part 3: Combined (Knee + Brain)\n\nTrain SimCLR on **both anatomies merged**. Multi-anatomy generalist model.\n\nExpected characteristics:\n- Most diverse training data → should learn general MRI features\n- t-SNE should show clear knee vs brain separation\n- May sacrifice per-anatomy specificity for generality\n- Useful as a universal artifact detector","metadata":{}},{"id":"9c45e792","cell_type":"code","source":"# ══════════════════════════════════════════════\n# PART 3: COMBINED — Data Loaders\n# ══════════════════════════════════════════════\nprint(\"Loading Combined (Knee + Brain) datasets...\")\naug = SimCLRAugmentMRI(IMG_SIZE)\n\n# Reload datasets for combined training\n# We use a wrapper that merges both anatomies but preserves label info\nclass CombinedSimCLRDataset(Dataset):\n    \"\"\"Merges multiple anatomy datasets with global label offsets.\"\"\"\n    def __init__(self, root_dirs, transform, name=\"\"):\n        self.transform = transform\n        self.paths = []\n        self.labels = []\n        self.label_map = {}\n\n        for root_dir in root_dirs:\n            paths, label_strs = find_npy_files(root_dir)\n            unique = sorted(set(label_strs))\n            for lbl in unique:\n                if lbl not in self.label_map:\n                    self.label_map[lbl] = len(self.label_map)\n            self.paths.extend(paths)\n            self.labels.extend([self.label_map[s] for s in label_strs])\n\n        print(f\"  [{name}] Loaded {len(self.paths)} slices | Labels: {self.label_map}\")\n\n    def __len__(self):\n        return len(self.paths)\n\n    def __getitem__(self, idx):\n        img = np.load(self.paths[idx]).astype(np.float32)\n        x1, x2 = self.transform(img)\n        return x1, x2, self.labels[idx]\n\n\nclass CombinedCleanDataset(Dataset):\n    \"\"\"Merges multiple anatomy datasets (clean, no augmentation).\"\"\"\n    def __init__(self, root_dirs, transform=None, name=\"\"):\n        self.transform = transform or CleanTransform()\n        self.paths = []\n        self.labels = []\n        self.label_map = {}\n\n        for root_dir in root_dirs:\n            paths, label_strs = find_npy_files(root_dir)\n            unique = sorted(set(label_strs))\n            for lbl in unique:\n                if lbl not in self.label_map:\n                    self.label_map[lbl] = len(self.label_map)\n            self.paths.extend(paths)\n            self.labels.extend([self.label_map[s] for s in label_strs])\n\n    def __len__(self):\n        return len(self.paths)\n\n    def __getitem__(self, idx):\n        img = np.load(self.paths[idx]).astype(np.float32)\n        return self.transform(img), self.labels[idx]\n\n\ncombined_train_ds = CombinedSimCLRDataset([KNEE_TRAIN, BRAIN_TRAIN], aug, name=\"Combined-Train\")\ncombined_val_ds   = CombinedSimCLRDataset([KNEE_VAL, BRAIN_VAL], aug, name=\"Combined-Val\")\n\ncombined_train_loader = DataLoader(combined_train_ds, batch_size=BATCH_SIZE, shuffle=True,\n                                   num_workers=NUM_WORKERS, pin_memory=True, drop_last=True)\ncombined_val_loader = DataLoader(combined_val_ds, batch_size=BATCH_SIZE, shuffle=False,\n                                 num_workers=NUM_WORKERS, pin_memory=True)\n\ncombined_train_clean = CombinedCleanDataset([KNEE_TRAIN, BRAIN_TRAIN], name=\"Combined-Train-Clean\")\ncombined_val_clean   = CombinedCleanDataset([KNEE_VAL, BRAIN_VAL], name=\"Combined-Val-Clean\")\n\ncombined_train_clean_loader = DataLoader(combined_train_clean, batch_size=BATCH_SIZE, shuffle=False,\n                                         num_workers=NUM_WORKERS, pin_memory=True)\ncombined_val_clean_loader = DataLoader(combined_val_clean, batch_size=BATCH_SIZE, shuffle=False,\n                                       num_workers=NUM_WORKERS, pin_memory=True)\n\nprint(f\"\\nCombined train: {len(combined_train_ds)} slices, {len(combined_train_loader)} batches\")\nprint(f\"Combined val:   {len(combined_val_ds)} slices, {len(combined_val_loader)} batches\")","metadata":{},"outputs":[],"execution_count":null},{"id":"dd9ae584","cell_type":"code","source":"# ══════════════════════════════════════════════\n# PART 3: COMBINED — Train SimCLR\n# ══════════════════════════════════════════════\nCOMBINED_SAVE = \"/kaggle/working/checkpoints/simclr_combined\"\ncombined_encoder, combined_projector, combined_history = train_simclr(\n    combined_train_loader, combined_val_loader, COMBINED_SAVE, model_name=\"SimCLR-Combined\"\n)","metadata":{},"outputs":[],"execution_count":null},{"id":"578120c2","cell_type":"code","source":"# ══════════════════════════════════════════════\n# PART 3: COMBINED — Full Analysis\n# ══════════════════════════════════════════════\ncombined_results = run_full_analysis(\n    combined_encoder, combined_train_clean_loader, combined_val_clean_loader,\n    combined_train_clean, combined_val_clean, combined_history, COMBINED_SAVE, \"SimCLR-Combined\"\n)","metadata":{},"outputs":[],"execution_count":null},{"id":"2c0850de","cell_type":"code","source":"# ══════════════════════════════════════════════\n# PART 3: COMBINED — Cleanup GPU\n# ══════════════════════════════════════════════\ndel combined_encoder, combined_projector\ndel combined_train_loader, combined_val_loader\ndel combined_train_clean_loader, combined_val_clean_loader\nclear_gpu()","metadata":{},"outputs":[],"execution_count":null},{"id":"0f8d5b02","cell_type":"markdown","source":"---\n# Summary & Comparison\n\nCompare the three models side-by-side on key metrics.","metadata":{}},{"id":"c7b19806","cell_type":"code","source":"# ══════════════════════════════════════════════\n# Cross-Model Comparison\n# ══════════════════════════════════════════════\nprint(\"\\n\" + \"=\" * 70)\nprint(\"  MODEL COMPARISON SUMMARY\")\nprint(\"=\" * 70)\n\n# Load scoring data from each model\nresults = {}\nfor name, save_dir in [(\"Knee\", KNEE_SAVE), (\"Brain\", BRAIN_SAVE), (\"Combined\", COMBINED_SAVE)]:\n    data = np.load(os.path.join(save_dir, \"scoring.npz\"), allow_pickle=True)\n    results[name] = {\n        \"train_scores\": data[\"train_scores\"],\n        \"val_scores\": data[\"val_scores\"],\n        \"threshold\": float(data[\"threshold_p95\"]),\n        \"train_feats\": data[\"train_feats\"],\n        \"val_feats\": data[\"val_feats\"],\n    }\n\n# Print comparison table\nprint(f\"\\n{'Model':<12} {'Train μ':<10} {'Train σ':<10} {'Val μ':<10} {'Val σ':<10} {'p95 Thresh':<12} {'Val>p95':<10}\")\nprint(\"-\" * 74)\nfor name, r in results.items():\n    ts, vs = r[\"train_scores\"], r[\"val_scores\"]\n    flagged = (vs > r[\"threshold\"]).sum()\n    print(f\"{name:<12} {ts.mean():<10.4f} {ts.std():<10.4f} {vs.mean():<10.4f} {vs.std():<10.4f} \"\n          f\"{r['threshold']:<12.4f} {flagged}/{len(vs)} ({100*flagged/len(vs):.1f}%)\")\n\n# Feature diversity comparison\nprint(f\"\\n{'Model':<12} {'Feature STD':<14} {'Mean Cos Sim':<14} {'Status'}\")\nprint(\"-\" * 54)\nfor name, r in results.items():\n    feats = r[\"val_feats\"][:2000]\n    std = np.std(feats, axis=0).mean()\n    sim = np.dot(feats, feats.T)\n    off = sim[np.triu_indices_from(sim, k=1)].mean()\n    status = \"✅ Good\" if off < 0.9 else \"⚠️ High sim\"\n    print(f\"{name:<12} {std:<14.4f} {off:<14.4f} {status}\")","metadata":{},"outputs":[],"execution_count":null},{"id":"dfa8da89","cell_type":"code","source":"# ══════════════════════════════════════════════\n# Comparative Loss Curves\n# ══════════════════════════════════════════════\nfig, axes = plt.subplots(1, 3, figsize=(18, 5))\nfig.suptitle(\"Training Loss Comparison (All Models)\", fontsize=14, y=1.02)\n\ncolors = {\"Knee\": \"tab:blue\", \"Brain\": \"tab:orange\", \"Combined\": \"tab:green\"}\n\n# Load histories\nhistories = {}\nfor name, save_dir in [(\"Knee\", KNEE_SAVE), (\"Brain\", BRAIN_SAVE), (\"Combined\", COMBINED_SAVE)]:\n    ckpt = torch.load(os.path.join(save_dir, \"final.pt\"), map_location=\"cpu\")\n    histories[name] = ckpt[\"history\"]\n\n# Train loss\nfor name, h in histories.items():\n    axes[0].plot(h[\"train_loss\"], label=name, linewidth=2, color=colors[name])\naxes[0].set_title(\"Train Loss\"); axes[0].set_xlabel(\"Epoch\")\naxes[0].legend(); axes[0].grid(True, alpha=0.3)\n\n# Val loss\nfor name, h in histories.items():\n    axes[1].plot(h[\"val_loss\"], label=name, linewidth=2, color=colors[name])\naxes[1].set_title(\"Val Loss\"); axes[1].set_xlabel(\"Epoch\")\naxes[1].legend(); axes[1].grid(True, alpha=0.3)\n\n# Score distributions overlaid\nfor name, r in results.items():\n    axes[2].hist(r[\"val_scores\"], bins=50, alpha=0.5, label=name, color=colors[name])\naxes[2].set_title(\"Val Anomaly Score Distributions\")\naxes[2].set_xlabel(\"kNN Distance\"); axes[2].legend()\naxes[2].grid(True, alpha=0.3)\n\nfig.tight_layout()\nfig.savefig(\"comparison_plots.png\", dpi=150, bbox_inches=\"tight\")\nplt.show()","metadata":{},"outputs":[],"execution_count":null},{"id":"101903ab","cell_type":"markdown","source":"---\n## Download All Checkpoints\n\nZip all three model checkpoints for download.","metadata":{}},{"id":"d059c7af","cell_type":"code","source":"# ══════════════════════════════════════════════\n# Zip & Download All Checkpoints\n# ══════════════════════════════════════════════\nimport shutil\nfrom IPython.display import FileLink, display\n\nfor name, save_dir in [(\"knee\", KNEE_SAVE), (\"brain\", BRAIN_SAVE), (\"combined\", COMBINED_SAVE)]:\n    zip_path = shutil.make_archive(f\"simclr_{name}_checkpoints\", \"zip\", root_dir=\".\", base_dir=save_dir)\n    size_mb = os.path.getsize(zip_path) / 1e6\n    print(f\"  {name}: {zip_path} ({size_mb:.1f} MB)\")\n    display(FileLink(zip_path))\n\n# Also zip everything together\nall_zip = shutil.make_archive(\"simclr_all_checkpoints\", \"zip\", root_dir=\".\", base_dir=\"checkpoints\")\nprint(f\"\\n  ALL: {all_zip} ({os.path.getsize(all_zip)/1e6:.1f} MB)\")\ndisplay(FileLink(all_zip))","metadata":{},"outputs":[],"execution_count":null}]}